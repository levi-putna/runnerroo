# Copy values into `.env.playwright.local` (gitignored). Playwright loads `.env.local` then overwrites with `.env.playwright.local` (see `playwright.config.ts`).

# --- Supabase (local) ---
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Mailpit (local Inbucket) ---
# MAILPIT_BASE_URL=http://127.0.0.1:54324

# --- Supabase service role (seeds password E2E user in global-setup) ---
# SUPABASE_SERVICE_ROLE_KEY=

# --- Assistant chat E2E (`tests/e2e/assistant-chat.spec.ts`) ---
# Required in the Playwright **and** dev server env for real `/api/chat` + judge:
# AI_GATEWAY_API_KEY=
# Optional judge model (defaults to `openai/gpt-5.4-nano`):
# PLAYWRIGHT_ASSISTANT_JUDGE_MODEL=
# Set to `0` to skip the LLM-as-judge assertion (chat + usage assertions still run):
# PLAYWRIGHT_ASSISTANT_JUDGE=0
