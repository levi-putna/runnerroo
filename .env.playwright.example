# Copy to `.env.playwright.local` (gitignored via `.env*`) and adjust ports from `yarn sb:status`.
# Playwright loads `.env.local` first, then overlays this file.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54421
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_from_supabase_status

# Mailpit web UI + API (matches `[inbucket]` port in `supabase/config.toml`).
MAILPIT_BASE_URL=http://127.0.0.1:54324

# Optional: seed a password user for `auth.spec` password sign-in (A6) and cross-account checks (A12).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_from_supabase_status

# Optional: override dev server URL if not using port 80.
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:80
